{
    "files.autoSave": "afterDelay",
    "chat.viewSessions.orientation": "stacked",
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "workbench.iconTheme": "material-icon-theme",
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "chat.mcp.gallery.enabled": true,
    "editor.fontFamily": "'JetBrainsMono Nerd Font', monospace",
    "editor.fontSize": 14,
    "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
    "workbench.colorCustomizations": {
        "editor.background": "#121318",
        "editor.foreground": "#e3e1e9",
        "activityBar.background": "#1f1f25",
        "activityBar.foreground": "#bac3ff",
        "sideBar.background": "#1b1b21",
        "sideBar.foreground": "#e3e1e9",
        "statusBar.background": "#1f1f25",
        "statusBar.foreground": "#c6c5d0",
        "tab.activeBackground": "#292a2f",
        "tab.inactiveBackground": "#1f1f25",
        "editorLineNumber.foreground": "#90909a",
        "focusBorder": "#bac3ff",
        "button.background": "#bac3ff",
        "button.foreground": "#222c61",
        "button.hoverBackground": "#394379",
        "textLink.foreground": "#bac3ff",
        "textLink.activeForeground": "#e5bad8",
        "titleBar.activeBackground": "#1f1f25",
        "titleBar.activeForeground": "#e3e1e9",
        "titleBar.inactiveBackground": "#1b1b21",
        "titleBar.inactiveForeground": "#90909a",
        "menubar.selectionBackground": "#292a2f",
        "menubar.selectionForeground": "#e3e1e9",
        "menu.background": "#1f1f25",
        "menu.foreground": "#e3e1e9",
        "menu.selectionBackground": "#394379",
        "menu.selectionForeground": "#dee1ff",
        "editorGroupHeader.tabsBackground": "#1b1b21",
        "editorGroupHeader.noTabsBackground": "#1b1b21",
        "panel.background": "#1f1f25",
        "panelTitle.activeForeground": "#bac3ff",
        "panelTitle.inactiveForeground": "#90909a",
        "panelTitle.activeBorder": "#bac3ff",
        "breadcrumb.background": "#121318",
        "editorPane.background": "#121318",
        "sideBarSectionHeader.background": "#292a2f",
        "sideBarSectionHeader.foreground": "#e3e1e9",
        "sideBarSectionHeader.border": "#46464f",
        "statusBar.noFolderBackground": "#1b1b21",
        "statusBar.noFolderForeground": "#e3e1e9",
        "statusBarItem.hoverBackground": "#292a2f",
        "statusBarItem.remoteBackground": "#434659",
        "statusBarItem.remoteForeground": "#dfe1f9",
        "welcomePage.tileBackground": "#1f1f25",
        "welcomePage.tileHoverBackground": "#292a2f",
        "welcomePage.tileBorder": "#46464f",
        "welcomePage.background": "#121318",
        "tab.activeBorder": "#bac3ff",
        "tab.activeBorderTop": "#bac3ff",
        "tab.activeModifiedBorder": "#e5bad8",
        "tab.inactiveModifiedBorder": "#90909a",
        "tab.unfocusedActiveBorder": "#46464f",
        "editorGroupHeader.tabsBorder": "#46464f",
        "auxiliaryBar.background": "#221a14",
        "auxiliaryBar.border": "#52443b",
        "auxiliaryBarTitle.activeForeground": "#ffb781",
        "auxiliaryBarTitle.inactiveForeground": "#9f8d83",
        "auxiliaryBarTitle.activeBorder": "#ffb781",
        "chat.requestBubbleBackground": "#1b2023",
        "chat.requestBubbleHoverBackground": "#252b2d",
        "chat.slashCommandBackground": "#344a52",
        "chat.slashCommandForeground": "#cee6f0",
        "chat.avatarBackground": "#252b2d",
        "chat.avatarForeground": "#dee3e6",
        "inlineChat.background": "#1b2023",
        "inlineChatInput.background": "#171c1e",
        "inlineChatInput.border": "#40484b",
        "inlineChatInput.focusBorder": "#86d1e9"
    },
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.svg": "default",
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
        "*.qrc": "qt-core.qrcEditor"
    },
    "telemetry.feedback.enabled": false,
    "telemetry.editStats.enabled": false
}