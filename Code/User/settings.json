{
    "files.autoSave": "afterDelay",
    "chat.viewSessions.orientation": "stacked",
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "workbench.iconTheme": "material-icon-theme",
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "chat.mcp.gallery.enabled": true,
    "editor.fontFamily": "'JetBrainsMono Nerd Font', monospace",
    "editor.fontSize": 14,
    "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
    "workbench.colorCustomizations": {
        "editor.background": "#1a110f",
        "editor.foreground": "#f1dfda",
        "activityBar.background": "#271d1b",
        "activityBar.foreground": "#ffb59f",
        "sideBar.background": "#231917",
        "sideBar.foreground": "#f1dfda",
        "statusBar.background": "#271d1b",
        "statusBar.foreground": "#d8c2bc",
        "tab.activeBackground": "#322825",
        "tab.inactiveBackground": "#271d1b",
        "editorLineNumber.foreground": "#a08c87",
        "focusBorder": "#ffb59f",
        "button.background": "#ffb59f",
        "button.foreground": "#561f0e",
        "button.hoverBackground": "#723522",
        "textLink.foreground": "#ffb59f",
        "textLink.activeForeground": "#d8c68d",
        "titleBar.activeBackground": "#271d1b",
        "titleBar.activeForeground": "#f1dfda",
        "titleBar.inactiveBackground": "#231917",
        "titleBar.inactiveForeground": "#a08c87",
        "menubar.selectionBackground": "#322825",
        "menubar.selectionForeground": "#f1dfda",
        "menu.background": "#271d1b",
        "menu.foreground": "#f1dfda",
        "menu.selectionBackground": "#723522",
        "menu.selectionForeground": "#ffdbd0",
        "editorGroupHeader.tabsBackground": "#231917",
        "editorGroupHeader.noTabsBackground": "#231917",
        "panel.background": "#271d1b",
        "panelTitle.activeForeground": "#ffb59f",
        "panelTitle.inactiveForeground": "#a08c87",
        "panelTitle.activeBorder": "#ffb59f",
        "breadcrumb.background": "#1a110f",
        "editorPane.background": "#1a110f",
        "sideBarSectionHeader.background": "#322825",
        "sideBarSectionHeader.foreground": "#f1dfda",
        "sideBarSectionHeader.border": "#53433f",
        "statusBar.noFolderBackground": "#231917",
        "statusBar.noFolderForeground": "#f1dfda",
        "statusBarItem.hoverBackground": "#322825",
        "statusBarItem.remoteBackground": "#5d4037",
        "statusBarItem.remoteForeground": "#ffdbd0",
        "welcomePage.tileBackground": "#271d1b",
        "welcomePage.tileHoverBackground": "#322825",
        "welcomePage.tileBorder": "#53433f",
        "welcomePage.background": "#1a110f",
        "tab.activeBorder": "#ffb59f",
        "tab.activeBorderTop": "#ffb59f",
        "tab.activeModifiedBorder": "#d8c68d",
        "tab.inactiveModifiedBorder": "#a08c87",
        "tab.unfocusedActiveBorder": "#53433f",
        "editorGroupHeader.tabsBorder": "#53433f",
        "auxiliaryBar.background": "#221a14",
        "auxiliaryBar.border": "#52443b",
        "auxiliaryBarTitle.activeForeground": "#ffb781",
        "auxiliaryBarTitle.inactiveForeground": "#9f8d83",
        "auxiliaryBarTitle.activeBorder": "#ffb781",
        "chat.requestBubbleBackground": "#1b2023",
        "chat.requestBubbleHoverBackground": "#252b2d",
        "chat.slashCommandBackground": "#344a52",
        "chat.slashCommandForeground": "#cee6f0",
        "chat.avatarBackground": "#252b2d",
        "chat.avatarForeground": "#dee3e6",
        "inlineChat.background": "#1b2023",
        "inlineChatInput.background": "#171c1e",
        "inlineChatInput.border": "#40484b",
        "inlineChatInput.focusBorder": "#86d1e9"
    },
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.svg": "default",
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
        "*.qrc": "qt-core.qrcEditor"
    },
    "telemetry.feedback.enabled": false,
    "telemetry.editStats.enabled": false
}