{
    "files.autoSave": "afterDelay",
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "workbench.iconTheme": "material-icon-theme",
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "chat.mcp.gallery.enabled": true,
    "editor.fontFamily": "'JetBrainsMono Nerd Font', monospace",
    "editor.fontSize": 14,
    "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
    "workbench.colorCustomizations": {
        "editor.background": "#111318",
        "editor.foreground": "#e1e2e9",
        "activityBar.background": "#1d2024",
        "activityBar.foreground": "#a4c9fe",
        "sideBar.background": "#191c20",
        "sideBar.foreground": "#e1e2e9",
        "statusBar.background": "#1d2024",
        "statusBar.foreground": "#c3c6cf",
        "tab.activeBackground": "#272a2f",
        "tab.inactiveBackground": "#1d2024",
        "editorLineNumber.foreground": "#8d9199",
        "focusBorder": "#a4c9fe",
        "button.background": "#a4c9fe",
        "button.foreground": "#00315c",
        "button.hoverBackground": "#1f4876",
        "textLink.foreground": "#a4c9fe",
        "textLink.activeForeground": "#d9bde3",
        "titleBar.activeBackground": "#1d2024",
        "titleBar.activeForeground": "#e1e2e9",
        "titleBar.inactiveBackground": "#191c20",
        "titleBar.inactiveForeground": "#8d9199",
        "menubar.selectionBackground": "#272a2f",
        "menubar.selectionForeground": "#e1e2e9",
        "menu.background": "#1d2024",
        "menu.foreground": "#e1e2e9",
        "menu.selectionBackground": "#1f4876",
        "menu.selectionForeground": "#d3e3ff",
        "editorGroupHeader.tabsBackground": "#191c20",
        "editorGroupHeader.noTabsBackground": "#191c20",
        "panel.background": "#1d2024",
        "panelTitle.activeForeground": "#a4c9fe",
        "panelTitle.inactiveForeground": "#8d9199",
        "panelTitle.activeBorder": "#a4c9fe",
        "breadcrumb.background": "#111318",
        "editorPane.background": "#111318",
        "sideBarSectionHeader.background": "#272a2f",
        "sideBarSectionHeader.foreground": "#e1e2e9",
        "sideBarSectionHeader.border": "#43474e",
        "statusBar.noFolderBackground": "#191c20",
        "statusBar.noFolderForeground": "#e1e2e9",
        "statusBarItem.hoverBackground": "#272a2f",
        "statusBarItem.remoteBackground": "#3c4758",
        "statusBarItem.remoteForeground": "#d8e3f8",
        "welcomePage.tileBackground": "#1d2024",
        "welcomePage.tileHoverBackground": "#272a2f",
        "welcomePage.tileBorder": "#43474e",
        "welcomePage.background": "#111318",
        "tab.activeBorder": "#a4c9fe",
        "tab.activeBorderTop": "#a4c9fe",
        "tab.activeModifiedBorder": "#d9bde3",
        "tab.inactiveModifiedBorder": "#8d9199",
        "tab.unfocusedActiveBorder": "#43474e",
        "editorGroupHeader.tabsBorder": "#43474e",
        "auxiliaryBar.background": "#221a14",
        "auxiliaryBar.border": "#52443b",
        "auxiliaryBarTitle.activeForeground": "#ffb781",
        "auxiliaryBarTitle.inactiveForeground": "#9f8d83",
        "auxiliaryBarTitle.activeBorder": "#ffb781",
        "chat.requestBubbleBackground": "#1b2023",
        "chat.requestBubbleHoverBackground": "#252b2d",
        "chat.slashCommandBackground": "#344a52",
        "chat.slashCommandForeground": "#cee6f0",
        "chat.avatarBackground": "#252b2d",
        "chat.avatarForeground": "#dee3e6",
        "inlineChat.background": "#1b2023",
        "inlineChatInput.background": "#171c1e",
        "inlineChatInput.border": "#40484b",
        "inlineChatInput.focusBorder": "#86d1e9"
    },
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.svg": "default",
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
        "*.qrc": "qt-core.qrcEditor"
    },
    "telemetry.feedback.enabled": false,
    "telemetry.editStats.enabled": false,
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "chat.viewSessions.orientation": "stacked",
    "github.copilot.chat.copilotMemory.enabled": true,
    "chat.disableAIFeatures": true
}