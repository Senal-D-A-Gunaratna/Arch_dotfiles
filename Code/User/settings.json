{
    "files.autoSave": "afterDelay",
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "workbench.iconTheme": "material-icon-theme",
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "chat.mcp.gallery.enabled": true,
    "editor.fontFamily": "'JetBrainsMono Nerd Font', monospace",
    "editor.fontSize": 14,
    "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
    "workbench.colorCustomizations": {
        "editor.background": "#18130b",
        "editor.foreground": "#ece1d4",
        "activityBar.background": "#241f17",
        "activityBar.foreground": "#f1be6d",
        "sideBar.background": "#201b13",
        "sideBar.foreground": "#ece1d4",
        "statusBar.background": "#241f17",
        "statusBar.foreground": "#d2c4b4",
        "tab.activeBackground": "#2f2921",
        "tab.inactiveBackground": "#241f17",
        "editorLineNumber.foreground": "#9b8f80",
        "focusBorder": "#f1be6d",
        "button.background": "#f1be6d",
        "button.foreground": "#432c00",
        "button.hoverBackground": "#604100",
        "textLink.foreground": "#f1be6d",
        "textLink.activeForeground": "#b6cea3",
        "titleBar.activeBackground": "#241f17",
        "titleBar.activeForeground": "#ece1d4",
        "titleBar.inactiveBackground": "#201b13",
        "titleBar.inactiveForeground": "#9b8f80",
        "menubar.selectionBackground": "#2f2921",
        "menubar.selectionForeground": "#ece1d4",
        "menu.background": "#241f17",
        "menu.foreground": "#ece1d4",
        "menu.selectionBackground": "#604100",
        "menu.selectionForeground": "#ffddae",
        "editorGroupHeader.tabsBackground": "#201b13",
        "editorGroupHeader.noTabsBackground": "#201b13",
        "panel.background": "#241f17",
        "panelTitle.activeForeground": "#f1be6d",
        "panelTitle.inactiveForeground": "#9b8f80",
        "panelTitle.activeBorder": "#f1be6d",
        "breadcrumb.background": "#18130b",
        "editorPane.background": "#18130b",
        "sideBarSectionHeader.background": "#2f2921",
        "sideBarSectionHeader.foreground": "#ece1d4",
        "sideBarSectionHeader.border": "#4f4539",
        "statusBar.noFolderBackground": "#201b13",
        "statusBar.noFolderForeground": "#ece1d4",
        "statusBarItem.hoverBackground": "#2f2921",
        "statusBarItem.remoteBackground": "#55442a",
        "statusBarItem.remoteForeground": "#f9dfbb",
        "welcomePage.tileBackground": "#241f17",
        "welcomePage.tileHoverBackground": "#2f2921",
        "welcomePage.tileBorder": "#4f4539",
        "welcomePage.background": "#18130b",
        "tab.activeBorder": "#f1be6d",
        "tab.activeBorderTop": "#f1be6d",
        "tab.activeModifiedBorder": "#b6cea3",
        "tab.inactiveModifiedBorder": "#9b8f80",
        "tab.unfocusedActiveBorder": "#4f4539",
        "editorGroupHeader.tabsBorder": "#4f4539",
        "auxiliaryBar.background": "#221a14",
        "auxiliaryBar.border": "#52443b",
        "auxiliaryBarTitle.activeForeground": "#ffb781",
        "auxiliaryBarTitle.inactiveForeground": "#9f8d83",
        "auxiliaryBarTitle.activeBorder": "#ffb781",
        "chat.requestBubbleBackground": "#1b2023",
        "chat.requestBubbleHoverBackground": "#252b2d",
        "chat.slashCommandBackground": "#344a52",
        "chat.slashCommandForeground": "#cee6f0",
        "chat.avatarBackground": "#252b2d",
        "chat.avatarForeground": "#dee3e6",
        "inlineChat.background": "#1b2023",
        "inlineChatInput.background": "#171c1e",
        "inlineChatInput.border": "#40484b",
        "inlineChatInput.focusBorder": "#86d1e9",
        "terminal.foreground": "#ece1d4",
        "terminalCursor.foreground": "#f1be6d",
        "terminal.ansiBlack": "#3a342b",
        "terminal.ansiRed": "#ffb4ab",
        "terminal.ansiGreen": "#b6cea3",
        "terminal.ansiYellow": "#55442a",
        "terminal.ansiBlue": "#f1be6d",
        "terminal.ansiMagenta": "#604100",
        "terminal.ansiCyan": "#dcc3a1",
        "terminal.ansiWhite": "#ece1d4",
        "terminal.ansiBrightBlack": "#9b8f80",
        "terminal.ansiBrightRed": "#93000a",
        "terminal.ansiBrightGreen": "#384c2c",
        "terminal.ansiBrightYellow": "#dcc3a1",
        "terminal.ansiBrightBlue": "#604100",
        "terminal.ansiBrightMagenta": "#55442a",
        "terminal.ansiBrightCyan": "#55442a",
        "terminal.ansiBrightWhite": "#d2c4b4",
        "list.activeSelectionBackground": "#604100",
        "list.activeSelectionForeground": "#ffddae",
        "list.hoverBackground": "#2f2921",
        "list.inactiveSelectionBackground": "#3a342b",
        "list.focusBackground": "#604100",
        "list.focusOutline": "#f1be6d",
        "explorer.indentGuidesCombined": "#4f4539"
    },
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.svg": "default",
        "{git,gitlens,chat-editing-snapshot-text-model,copilot,git-graph,git-graph-3}:/**/*.qrc": "default",
        "*.qrc": "qt-core.qrcEditor"
    },
    "telemetry.feedback.enabled": false,
    "telemetry.editStats.enabled": false,
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "chat.viewSessions.orientation": "stacked",
    "github.copilot.chat.copilotMemory.enabled": true,
    "chat.disableAIFeatures": true,
    "diffEditor.codeLens": true
}