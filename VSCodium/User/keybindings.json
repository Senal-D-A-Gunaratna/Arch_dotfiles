[
    // 1. Maximize the panel when it is currently minimized/small
    {
        "key": "alt+q",
        "command": "workbench.action.toggleMaximizedPanel",
        "when": "panelVisible && !panelMaximized"
    },
    // 2. Restore the panel to its original size when it is currently maximized
    {
        "key": "alt+q",
        "command": "workbench.action.toggleMaximizedPanel",
        "when": "panelMaximized"
    },
    {
        "key": "alt+a",
        "command": "geminicodeassist.showinEditor",
        "when": "authLoggedIn && config.geminicodeassist.enable && editorTextFocus && shouldRegisterInEditorCommand && !inGeminiDiffView && !isInDiffEditor"
    },
]