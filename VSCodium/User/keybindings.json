[
    // Toggle the panel between maximized and its original size
    {
        "key": "alt+q",
        "command": "workbench.action.toggleMaximizedPanel",
        "when": "panelVisible || panelMaximized"
    },
    {
        "key": "alt+`",
        "command": "geminicodeassist.showinEditor",
        "when": "authLoggedIn && config.geminicodeassist.enable && editorTextFocus && shouldRegisterInEditorCommand && !inGeminiDiffView && !isInDiffEditor && !sidePanelVisible"
    },
    {
        "key": "alt+`",
        "command": "workbench.action.closeSidePanel",
        "when": "sidePanelVisible"
    }
]